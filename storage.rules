rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }
    function safeFile() {
      return request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }

    // Student homework uploads from the public portal.
    match /homework/{studentCode}/{fileName} {
      allow read: if true;
      allow create: if safeFile();
      allow update, delete: if false;
    }

    // Teacher dashboard uploads for materials, questions and exams.
    match /teacher-uploads/{fileName} {
      allow read: if true;
      allow write: if signedIn() && safeFile();
    }

    match /public/uploads/{fileName} {
      allow read: if true;
      allow write: if signedIn() && safeFile();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
