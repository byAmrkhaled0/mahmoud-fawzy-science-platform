{
  "name": "mahmoud-fawzy-science-platform-secure-mobile",
  "version": "44.0.0",
  "private": true,
  "scripts": {
    "dev": "node local-server.js",
    "preview": "node local-server.js",
    "build": "node scripts/build.js",
    "firebase:rules": "firebase deploy --only firestore:rules,firestore:indexes,storage",
    "firebase:functions": "firebase deploy --only functions",
    "firebase:hosting": "npm run build && firebase deploy --only hosting",
    "test": "node scripts/verify.js",
    "firebase:deploy:backend": "firebase deploy --only firestore:rules,firestore:indexes,storage,functions",
    "firebase:deploy:all": "npm run test && npm run build && firebase deploy --only firestore:rules,firestore:indexes,storage,functions,hosting"
  },
  "engines": {
    "node": "24.x"
  }
}
