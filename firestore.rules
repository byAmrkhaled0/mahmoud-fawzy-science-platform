rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userPath() { return /databases/$(database)/documents/users/$(request.auth.uid); }
    function hasUserDoc() { return signedIn() && exists(userPath()); }
    function userData() { return get(userPath()).data; }
    function isActive() { return hasUserDoc() && userData().active != false; }
    function isAdmin() { return isActive() && userData().role == 'admin'; }
    function isTeacher() { return isActive() && userData().role in ['admin', 'teacher']; }
    function isAssistant() { return isActive() && userData().role == 'assistant'; }
    function isStaff() { return isTeacher() || isAssistant(); }
    function strOk(value, max) { return value is string && value.size() <= max; }
    function validCode(value) {
      return value is string && value.size() >= 6 && value.size() <= 40
        && value.matches('^[A-Za-z0-9_-]+$');
    }
    function validPhone(value) {
      return value is string && value.size() >= 8 && value.size() <= 20
        && value.matches('^[0-9+ ()-]+$');
    }
    function bookingFields() {
      return request.resource.data.keys().hasOnly([
        'id','code','name','studentName','studentPhone','parentPhone','grade','month',
        'group','notes','status','date','createdAt','updatedAt'
      ]);
    }
    function bookingStatusFields() {
      return request.resource.data.keys().hasOnly([
        'code','name','grade','month','group','status','studentCode','parentCode','updatedAt'
      ]);
    }
    function reviewFields() {
      return request.resource.data.keys().hasOnly([
        'id','name','role','rating','text','date','approved','createdAt','updatedAt'
      ]);
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isStaff());
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} { allow read, write: if isStaff(); }
    match /students/{studentCode} {
      allow read: if isStaff();
      allow create, update: if isStaff() && validCode(studentCode);
      allow delete: if isTeacher();
    }
    match /student_portal/{studentCode} {
      allow read, create, update: if isStaff();
      allow delete: if isTeacher();
    }
    match /parent_portal/{parentCode} {
      allow read, create, update: if isStaff();
      allow delete: if isTeacher();
    }

    // Primary path is Cloud Functions. This tightly validated create rule is a reliability fallback.
    match /bookings/{bookingCode} {
      allow create: if bookingFields()
        && validCode(bookingCode)
        && request.resource.data.code == bookingCode
        && request.resource.data.id == bookingCode
        && strOk(request.resource.data.name, 80)
        && request.resource.data.name.size() >= 3
        && validPhone(request.resource.data.studentPhone)
        && validPhone(request.resource.data.parentPhone)
        && request.resource.data.studentPhone != request.resource.data.parentPhone
        && strOk(request.resource.data.grade, 80)
        && strOk(request.resource.data.month, 40)
        && strOk(request.resource.data.group, 100)
        && strOk(request.resource.data.notes, 1000)
        && request.resource.data.status == 'بانتظار الموافقة';
      allow read, update: if isStaff();
      allow delete: if isTeacher();
    }

    // Contains no phone numbers and is only readable with the hard-to-guess booking code.
    match /booking_status/{bookingCode} {
      allow get: if validCode(bookingCode);
      allow list: if false;
      allow create: if bookingStatusFields()
        && validCode(bookingCode)
        && request.resource.data.code == bookingCode
        && strOk(request.resource.data.name, 80)
        && strOk(request.resource.data.grade, 80)
        && strOk(request.resource.data.month, 40)
        && strOk(request.resource.data.group, 100)
        && request.resource.data.status == 'بانتظار الموافقة'
        && request.resource.data.studentCode == ''
        && request.resource.data.parentCode == '';
      allow read, update: if isStaff();
      allow delete: if isTeacher();
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.approved == true || isStaff();
      allow create: if reviewFields()
        && strOk(request.resource.data.name, 60)
        && request.resource.data.name.size() >= 2
        && strOk(request.resource.data.text, 600)
        && request.resource.data.text.size() >= 5
        && request.resource.data.approved == false;
      allow update, delete: if isStaff();
    }

    match /materials/{id} { allow read: if true; allow write: if isStaff(); }
    match /questions/{id} { allow read: if true; allow write: if isStaff(); }
    match /groups/{id} { allow read: if true; allow write: if isStaff(); }
    match /assignments/{id} { allow read: if true; allow write: if isStaff(); }
    match /exams/{id} { allow read, write: if isStaff(); }
    match /exam_sessions/{id} { allow read, write: if false; }
    match /exam_locks/{id} { allow read, write: if false; }
    match /exam_attempts/{id} {
      allow read: if isStaff(); allow update, delete: if isTeacher(); allow create: if false;
    }
    match /student_attempts/{studentCode} { allow read: if isStaff(); allow write: if false; }
    match /student_attempts/{studentCode}/attempts/{attemptId} { allow read: if isStaff(); allow write: if false; }
    match /homework_submissions/{id} {
      allow read, update: if isStaff(); allow delete: if isTeacher(); allow create: if false;
    }
    match /attendance/{id} { allow read, create, update: if isStaff(); allow delete: if isTeacher(); }
    match /recitations/{id} { allow read, create, update: if isStaff(); allow delete: if isTeacher(); }
    match /grades/{id} { allow read, create, update: if isStaff(); allow delete: if isTeacher(); }
    match /payments/{id} { allow read, create, update: if isStaff(); allow delete: if isTeacher(); }
    match /reports/{id} { allow read, create, update: if isStaff(); allow delete: if isTeacher(); }
    match /activityLog/{id} { allow read, create: if isStaff(); allow update, delete: if isAdmin(); }
    match /client_errors/{id} { allow read, delete: if isTeacher(); allow create, update: if false; }
    match /_rate_limits/{id} { allow read, write: if false; }
    match /{document=**} { allow read, write: if false; }
  }
}
