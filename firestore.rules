rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasUserDoc() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isAdmin() { return hasUserDoc() && userDoc().role == 'admin' && userDoc().active == true; }
    function isAssistant() { return hasUserDoc() && userDoc().role == 'assistant' && userDoc().active == true; }
    function isStaff() { return isAdmin() || isAssistant(); }
    function publicBookingFields() { return request.resource.data.keys().hasOnly(['id','code','name','studentPhone','parentPhone','grade','month','group','notes','status','date','createdAt','updatedAt']); }
    function publicReviewFields() { return request.resource.data.keys().hasOnly(['id','name','role','rating','text','date','approved','createdAt']); }
    match /users/{userId} { allow read: if signedIn() && (request.auth.uid == userId || isStaff()); allow create: if signedIn() && request.auth.uid == userId; allow update, delete: if isAdmin(); }
    match /settings/{docId} { allow read: if true; allow write: if isStaff(); }
    match /bookings/{id} { allow create: if publicBookingFields(); allow read, update, delete: if isStaff(); }
    match /reviews/{id} { allow read: if true; allow create: if publicReviewFields(); allow update, delete: if isStaff(); }
    match /materials/{id} { allow read: if true; allow write: if isStaff(); }
    match /questions/{id} { allow read: if true; allow write: if isStaff(); }
    match /groups/{id} { allow read: if true; allow write: if isStaff(); }
    match /assignments/{id} { allow read: if true; allow write: if isStaff(); }
    match /exams/{id} { allow read: if true; allow write: if isStaff(); }
    match /exam_attempts/{id} { allow create: if true; allow read, update, delete: if isStaff(); }
    match /homework_submissions/{id} { allow create: if true; allow read, update, delete: if isStaff(); }
    match /students/{id} { allow read, write: if isStaff(); allow read: if signedIn() && (userDoc().studentId == id || userDoc().childStudentId == id); }
    match /attendance/{id} { allow read, write: if isStaff(); }
    match /recitations/{id} { allow read, write: if isStaff(); }
    match /grades/{id} { allow read, write: if isStaff(); }
    match /payments/{id} { allow read, write: if isStaff(); }
    match /reports/{id} { allow read, write: if isStaff(); }
    match /activityLog/{id} { allow read, write: if isStaff(); }
    match /{document=**} { allow read, write: if false; }
  }
}
