rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userPath() { return /databases/$(database)/documents/users/$(request.auth.uid); }
    function hasUserDoc() { return signedIn() && exists(userPath()); }
    function userData() { return get(userPath()).data; }
    function isActive() { return hasUserDoc() && userData().active != false; }
    function isAdmin() { return isActive() && userData().role == 'admin'; }
    function isTeacher() { return isActive() && userData().role in ['admin', 'teacher']; }
    function isAssistant() { return isActive() && userData().role == 'assistant'; }
    function isStaff() { return isTeacher() || isAssistant(); }
    function strOk(value, max) { return value is string && value.size() <= max; }
    function validCode(value) {
      return value is string
        && value.size() >= 6
        && value.size() <= 40
        && value.matches('^[A-Za-z0-9_-]+$');
    }
    function homeworkFields() {
      return request.resource.data.keys().hasOnly([
        'studentCode', 'fileName', 'fileUrl', 'filePath', 'path', 'url',
        'contentType', 'size', 'createdAt', 'updatedAt'
      ]);
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isStaff());
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read, write: if isStaff();
    }

    match /students/{studentCode} {
      allow read: if isStaff();
      allow create, update: if isStaff() && validCode(studentCode);
      allow delete: if isTeacher();
    }

    // بوابات الأكواد لا تُقرأ مباشرة من المتصفح العام.
    // القراءة العامة تتم من Cloud Functions مع rate limiting وApp Check.
    match /student_portal/{studentCode} {
      allow read, create, update: if isStaff();
      allow delete: if isTeacher();
    }

    match /parent_portal/{parentCode} {
      allow read, create, update: if isStaff();
      allow delete: if isTeacher();
    }

    // إنشاء الحجز ومتابعته يتمان من Cloud Functions فقط.
    match /bookings/{bookingCode} {
      allow read, update: if isStaff();
      allow delete: if isTeacher();
      allow create: if false;
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.approved == true || isStaff();
      allow create: if false;
      allow update, delete: if isStaff();
    }

    match /materials/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /questions/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /groups/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /assignments/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // الإجابات الصحيحة داخل مستند الامتحان، لذلك القراءة للموظفين فقط.
    match /exams/{id} {
      allow read, write: if isStaff();
    }

    // إنشاء وتسليم المحاولات يتمان من Cloud Functions فقط.
    match /exam_sessions/{id} {
      allow read, write: if false;
    }

    match /exam_locks/{id} {
      allow read, write: if false;
    }

    match /exam_attempts/{id} {
      allow read: if isStaff();
      allow update: if isTeacher();
      allow delete: if isTeacher();
      allow create: if false;
    }

    match /student_attempts/{studentCode} {
      allow read: if isStaff();
      allow write: if false;
    }

    match /student_attempts/{studentCode}/attempts/{attemptId} {
      allow read: if isStaff();
      allow write: if false;
    }

    match /homework_submissions/{id} {
      allow read, update: if isStaff();
      allow delete: if isTeacher();
      allow create: if false;
    }

    match /attendance/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isTeacher();
    }

    match /recitations/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isTeacher();
    }

    match /grades/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isTeacher();
    }

    match /payments/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isTeacher();
    }

    match /reports/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isTeacher();
    }

    match /activityLog/{id} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /client_errors/{id} {
      allow read, delete: if isTeacher();
      allow create, update: if false;
    }

    match /_rate_limits/{id} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
